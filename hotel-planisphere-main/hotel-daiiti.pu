@startuml test

' テーブル: プラン
entity "プラン" as Plan {
    *プランID : INT
    非会員表示 : BOOLEAN
    会員限定表示 : BOOLEAN
    プレミアム会員限定表示 : BOOLEAN
    特典付きプラン説明 : TEXT
    価格 : INT <<お一人様1泊7000円〜>>
    土日割増率 : INT <<25%アップ>>
    最少人数 : INT <<1名様>>
    最大人数 : INT <<9名様>>
    最長泊数 : INT <<9泊>>
    部屋タイプID : INT
}

' テーブル: 予約
entity "予約" as Reservation {
    *予約ID : INT
    宿泊日 : DATE <<必須>>
    宿泊数 : INT <<1泊が基本>>
    人数 : INT <<必須>>
    氏名 : VARCHAR <<必須>>
    追加プラン_朝食バイキング : BOOLEAN
    追加プラン_昼からチェックイン : BOOLEAN
    追加プラン_観光プラン : BOOLEAN
    確認連絡方法 : VARCHAR <<希望しない/メール/電話>>
    要望連絡事項 : TEXT
    合計金額 : INT
    部屋タイプID : INT
    プランID : INT
}

' テーブル: 部屋タイプ
entity "部屋タイプ" as RoomType {
    *部屋タイプID : INT
    タイプ名 : VARCHAR <<例：スタンダードツイン>>
    ベッドタイプ : VARCHAR <<例：ツイン>>
    定員数 : INT <<1〜2名>>
    部屋面積 : INT <<単位:㎡>>
}

' テーブル: 設備
entity "設備" as Facility {
    *設備ID : INT
    設備名 : VARCHAR
    説明 : VARCHAR
    カテゴリ : VARCHAR <<例：バス・トイレ、アメニティ、家電など>>
    部屋タイプID : INT
}

' テーブル: 会員登録
entity "会員登録" as Member {
    *会員ID : INT
    メールアドレス : VARCHAR <<必須>>
    パスワード : VARCHAR <<8文字以上>>
    氏名 : VARCHAR <<必須>>
    会員タイプ : VARCHAR <<プレミアム/一般>>
    住所 : VARCHAR
    電話番号 : VARCHAR <<11桁の数字>>
    性別 : VARCHAR <<男性/女性/その他>>
    生年月日 : DATE
    お知らせ受信 : BOOLEAN
    アイコン画像パス : VARCHAR
    アイコン拡大縮小 : INT <<range 0-100>>
    アイコン枠線色 : VARCHAR <<カラーコード>>
}

' リレーション
Facility -- RoomType : 部屋タイプの設備
Plan -- RoomType : 部屋タイプに紐づく
Reservation -- RoomType : 部屋タイプを予約
Reservation -- Plan : プランを予約
Reservation -- Member : 予約者(会員)

@enduml
