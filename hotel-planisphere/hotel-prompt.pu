@startuml hotel

entity "部屋タイプ" as RoomType {
    *部屋タイプID : INT
    名称 : VARCHAR
    ベッドタイプ : VARCHAR
    定員数 : INT
    面積 : INT <<㎡>>
}

entity "設備" as Facility {
    *設備ID : INT
    設備名 : VARCHAR
    説明 : VARCHAR
    カテゴリ : VARCHAR
    部屋タイプID : INT
}

entity "プラン" as Plan {
    *プランID : INT
    名称 : VARCHAR
    説明 : TEXT
    基本価格 : INT
    土日割増率 : INT
    最少人数 : INT
    最大人数 : INT
    最長泊数 : INT
    非会員表示 : BOOLEAN
    会員限定表示 : BOOLEAN
    プレミアム限定表示 : BOOLEAN
    部屋タイプID : INT
}

entity "おすすめプラン" as FeaturedPlan {
    *おすすめID : INT
    プランID : INT
    表示開始日 : DATE
    表示終了日 : DATE
    説明 : TEXT
}

entity "会員" as Member {
    *会員ID : INT
    氏名 : VARCHAR
    メールアドレス : VARCHAR
    パスワード : VARCHAR
    会員タイプID : INT
    住所 : VARCHAR
    電話番号 : VARCHAR
    性別 : VARCHAR
    生年月日 : DATE
    お知らせ受信 : BOOLEAN
}

entity "会員タイプ" as MemberType {
    *会員タイプID : INT
    名称 : VARCHAR <<一般/プレミアムなど>>
}

entity "アイコン設定" as IconSetting {
    *会員ID : INT <<PK/FK>>
    画像パス : VARCHAR
    拡大縮小 : INT
    枠線色 : VARCHAR
}

entity "予約" as Reservation {
    *予約ID : INT
    会員ID : INT
    プランID : INT
    部屋タイプID : INT
    宿泊日 : DATE
    宿泊数 : INT
    人数 : INT
    氏名 : VARCHAR
    確認連絡方法 : VARCHAR
    要望 : TEXT
    合計金額 : INT
}

entity "追加プラン" as AddOnPlan {
    *追加プランID : INT
    名称 : VARCHAR
    価格 : INT
}

entity "予約追加プラン" as ReservationAddOn {
    *予約追加プランID : INT
    予約ID : INT
    追加プランID : INT
}

Facility -- RoomType : 部屋タイプの設備
Plan -- RoomType : 使用部屋タイプ
FeaturedPlan -- Plan : 対象プラン
Member -- MemberType : 種類
IconSetting -- Member : 会員の拡張設定
Reservation -- Member : 予約者
Reservation -- Plan : プラン指定
Reservation -- RoomType : 部屋指定
ReservationAddOn -- Reservation : 紐づく予約
ReservationAddOn -- AddOnPlan : 紐づく追加プラン

@enduml
